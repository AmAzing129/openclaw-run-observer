{
  "name": "openclaw-run-observer",
  "version": "0.0.1",
  "type": "module",
  "description": "Capture OpenClaw run inputs, outputs, usage, and context, persist recent attempts, and inspect them in a live local viewer.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmAzing129/openclaw-run-observer.git"
  },
  "homepage": "https://github.com/AmAzing129/openclaw-run-observer#readme",
  "bugs": {
    "url": "https://github.com/AmAzing129/openclaw-run-observer/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "llm",
    "observability",
    "tracing"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "dev": "node ./scripts/dev.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openclaw": "^2026.4.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.1",
      "minGatewayVersion": "2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.4.1"
    }
  }
}
